# CAPProbe configuration
# Copy to `.env` and fill in for LIVE mode. The offline demo (`npm run demo`) and
# unit tests (`npm test`) need NONE of these -- they run on the in-process mock.

# Mode: "mock" (offline, default) or "live" (real CAP, real USDC on Base).
CROO_MODE=mock

# --- Live credentials (required only when CROO_MODE=live) ---
# Agent Store SDK-Key from https://agent.croo.network/ after registering your
# agent. Format: croo_sk_...  This is the ONLY credential the SDK needs at runtime
# (the agent AA wallet is managed server-side).
CROO_API_KEY=croo_sk_REPLACE_ME

# Optional. Only used by the one-time wallet deploy/fund step, NOT the SDK runtime.
# Leave blank unless a CROO CLI step asks for it. NEVER commit a real key.
WALLET_PRIVATE_KEY=

# --- CAP endpoints (defaults; override only if instructed) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# --- Service identity ---
# The serviceId you list CAPProbe under on the Agent Store.
CAPPROBE_SERVICE_ID=capprobe.conformance.v1
# Default target the CLI / demo probes when none is given.
TARGET_SERVICE_ID=demo.echo.v1
# Advertised price per probe, in USDC.
PROBE_PRICE_USDC=0.50

# --- CLI / CI gate ---
# Minimum score for `npm run probe` to exit 0 (used by the GitHub Action).
MIN_SCORE=60

# --- Logging ---
# Levels: debug | info | warn | error | silent
LOG_LEVEL=info
# Set to "true" for machine-readable line-JSON logs.
LOG_JSON=false
# Mock-only: simulated per-hop latency in ms.
MOCK_LATENCY_MS=10
